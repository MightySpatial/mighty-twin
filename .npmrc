engine-strict=true
auto-install-peers=true

# @mightyspatial/* sourced LOCALLY in dev via pnpm.overrides in
# package.json. CI/prod will flip to GitHub Packages once v0.1.0 is
# published and a NODE_AUTH_TOKEN with read:packages is provided.
#
# @mightyspatial:registry=https://npm.pkg.github.com
# //npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
