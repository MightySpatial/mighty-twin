{
  "name": "@mightyspatial/cesium-core",
  "version": "0.1.0",
  "description": "Cesium viewer wrapper, camera hooks, and picking helpers — the foundation every Mighty widget builds on",
  "license": "UNLICENSED",
  "sideEffects": false,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src", "dist", "README.md"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@mightyspatial/types": "workspace:*"
  },
  "peerDependencies": {
    "cesium": ">=1.126",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "cesium": "^1.126.0",
    "react": "^18.3.1"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts"
  }
}
