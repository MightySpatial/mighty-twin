{
  "name": "mighty-twin",
  "version": "0.1.0",
  "private": true,
  "description": "MightyTwin — enterprise on-prem digital twin backed by PostgreSQL/PostGIS. Thin consumer of @mightyspatial/* packages.",
  "author": "Mighty Spatial (Rahman Schionning)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @mighty-twin/web dev",
    "build": "pnpm --filter @mighty-twin/web build",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@mightyspatial/admin-panels": "link:../mighty-platform/packages/admin-panels",
      "@mightyspatial/app-shell": "link:../mighty-platform/packages/app-shell",
      "@mightyspatial/cesium-core": "link:../mighty-platform/packages/cesium-core",
      "@mightyspatial/settings-panels": "link:../mighty-platform/packages/settings-panels",
      "@mightyspatial/tokens": "link:../mighty-platform/packages/tokens",
      "@mightyspatial/types": "link:../mighty-platform/packages/types",
      "@mightyspatial/ui": "link:../mighty-platform/packages/ui",
      "@mightyspatial/utils": "link:../mighty-platform/packages/utils",
      "@mightyspatial/widget-host": "link:../mighty-platform/packages/widget-host",
      "@mightyspatial/widget-measure": "link:../mighty-platform/packages/widgets/measure"
    }
  }
}
